{
  "manifest_version": 3,
  "name": "Memory Lane Snapshot",
  "version": "0.1.0",
  "description": "AI-powered personal content organizer",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Memory Lane"
  },
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
